<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Student Registration</title>
  <style>
    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    body {
      background-color: #1a3a5c;
      display: flex;
      justify-content: center;
      align-items: center;
      min-height: 100vh;
      font-family: Arial, sans-serif;
    }

    .form-container {
      background-color: #d6eaf8;
      padding: 30px;
      border-radius: 8px;
      width: 420px;
      box-shadow: 0 4px 15px rgba(0,0,0,0.3);
    }

    h2 {
      text-align: center;
      margin-bottom: 20px;
      color: #1a3a5c;
      font-size: 20px;
    }

    label {
      display: block;
      font-size: 13px;
      font-weight: bold;
      margin-bottom: 4px;
      color: #1a3a5c;
    }

    input[type="text"],
    input[type="email"],
    input[type="tel"],
    input[type="date"],
    select {
      width: 100%;
      padding: 8px 10px;
      border: 1px solid #aac4d8;
      border-radius: 4px;
      font-size: 13px;
      background-color: #fff;
      color: #555;
      margin-bottom: 14px;
    }

    .row {
      display: flex;
      gap: 12px;
    }

    .row > div {
      flex: 1;
    }

    .gender-group {
      margin-bottom: 14px;
    }

    .gender-group label {
      font-size: 13px;
      font-weight: bold;
      margin-bottom: 6px;
    }

    .gender-options {
      display: flex;
      gap: 16px;
      font-size: 13px;
      color: #333;
    }

    .gender-options label {
      font-weight: normal;
      display: flex;
      align-items: center;
      gap: 4px;
      cursor: pointer;
    }

    button[type="submit"] {
      width: 100%;
      padding: 11px;
      background-color: #1a3a5c;
      color: white;
      font-size: 15px;
      border: none;
      border-radius: 5px;
      cursor: pointer;
      margin-top: 6px;
    }

    button[type="submit"]:hover {
      background-color: #154d7a;
    }
  </style>
</head>
<body>

  <div class="form-container">
    <h2>Registration Form</h2>

    <label for="fullname">Full Name</label>
    <input type="text" id="fullname" placeholder="Enter full name" />

    <label for="email">Email Address</label>
    <input type="email" id="email" placeholder="Enter email address" />

    <div class="row">
      <div>
        <label for="phone">Phone Number</label>
        <input type="tel" id="phone" placeholder="Enter phone number" />
      </div>
      <div>
        <label for="dob">Birth Date</label>
        <input type="date" id="dob" />
      </div>
    </div>

    <div class="gender-group">
      <label>Gender</label>
      <div class="gender-options">
        <label><input type="radio" name="gender" value="male" checked /> Male</label>
        <label><input type="radio" name="gender" value="female" /> Female</label>
        <label><input type="radio" name="gender" value="prefer_not" /> Prefer not to say</label>
      </div>
    </div>

    <label for="address1">Address</label>
    <input type="text" id="address1" placeholder="Enter street address" />
    <input type="text" id="address2" placeholder="Enter street address line 2" />

    <div class="row">
      <div>
        <label for="country">Country</label>
        <select id="country">
          <option value="">Country</option>
          <option value="america">America</option>
          <option value="japan">Japan</option>
          <option value="india">India</option>
          <option value="nepal">Nepal</option>
        </select>
      </div>
      <div>
        <label for="city">City</label>
        <input type="text" id="city" placeholder="Enter your city" />
      </div>
    </div>

    <label for="postal">Postal Code</label>
    <input type="text" id="postal" placeholder="Enter postal code" />

    <button type="submit">Submit</button>
  </div>

</body>
</html>